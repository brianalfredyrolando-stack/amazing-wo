# Connection string PostgreSQL dari Neon (gratis) — lihat DEPLOY.md.
# Contoh: postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Wajib diganti string acak min 32 karakter:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="ganti-dengan-string-acak-panjang-min-32-karakter-untuk-produksi"

# Akun owner pertama (dibuat saat seed). Ganti sebelum deploy.
OWNER_NAME="Owner WO"
OWNER_EMAIL="owner@weddingco.id"
OWNER_PASSWORD="owner12345"
